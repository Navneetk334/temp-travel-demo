datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS
// ==========================================

enum UserRole {
  CUSTOMER
  DRIVER
  CORPORATE_SPOC
}

enum AdminRole {
  SUPER_ADMIN
  MANAGER
  DISPATCHER
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  MAINTENANCE
  INACTIVE
}

enum BookingType {
  AIRPORT_TRANSFER
  LOCAL_RENTAL
  OUTSTATION
  TOUR_PACKAGE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  DRIVER_ASSIGNED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum OutstationType {
  ONE_WAY
  ROUND_TRIP
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
  ARCHIVED
}

// ==========================================
// MODULE 1: Users
// ==========================================

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  phone        String        @unique
  role         UserRole      @default(CUSTOMER)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  bookings     Booking[]
  vehicle      FleetVehicle? @relation("DriverVehicle")

  @@index([email])
  @@index([role])
}

// ==========================================
// MODULE 2: Admins
// ==========================================

model Admin {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  role         AdminRole  @default(MANAGER)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  blogPosts    BlogPost[]

  @@index([email])
}

// ==========================================
// MODULE 4: Package Categories
// ==========================================

model PackageCategory {
  id           String        @id @default(uuid())
  name         String
  slug         String        @unique
  description  String?       @db.Text
  imageUrl     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tourPackages TourPackage[]

  @@index([slug])
}

// ==========================================
// MODULE 3: Tour Packages
// ==========================================

model TourPackage {
  id             String          @id @default(uuid())
  title          String
  slug           String          @unique
  description    String          @db.Text
  itinerary      Json            // Array of days containing { day: number, title: string, description: string }
  durationDays   Int
  durationNights Int
  basePrice      Decimal         @db.Decimal(10, 2)
  inclusions     String[]
  exclusions     String[]
  images         String[]
  status         String          @default("DRAFT") // DRAFT, ACTIVE, ARCHIVED
  categoryId     String
  category       PackageCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  bookings       Booking[]

  @@index([slug])
  @@index([categoryId, status])
}

// ==========================================
// MODULE 6: Vehicle Categories
// ==========================================

model VehicleCategory {
  id               String        @id @default(uuid())
  name             String        @unique // e.g. SEDAN, SUV, PREMIUM, BUS, TEMPO
  slug             String        @unique
  description      String?       @db.Text
  imageUrl         String?
  baseHourlyRate   Decimal       @db.Decimal(10, 2)
  baseKmsRate      Decimal       @db.Decimal(10, 2)
  extraHrRate      Decimal       @db.Decimal(10, 2)
  extraKmRate      Decimal       @db.Decimal(10, 2)
  outstationKmRate Decimal       @db.Decimal(10, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  vehicles         FleetVehicle[]
  bookings         Booking[]
  rentalLeads      RentalLead[]

  @@index([slug])
}

// ==========================================
// MODULE 5: Fleet Vehicles
// ==========================================

model FleetVehicle {
  id                 String          @id @default(uuid())
  model              String
  make               String
  registrationNumber String          @unique
  categoryId         String
  category           VehicleCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  capacity           Int
  status             VehicleStatus   @default(AVAILABLE)
  driverId           String?         @unique
  driver             User?           @relation("DriverVehicle", fields: [driverId], references: [id], onDelete: SetNull)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  bookings           Booking[]

  @@index([categoryId])
  @@index([status])
}

// ==========================================
// MODULE 7: Corporate Leads
// ==========================================

model CorporateLead {
  id              String     @id @default(uuid())
  companyName     String
  contactName     String
  email           String
  phone           String
  employeeCount   Int?
  pickupLocations String?    @db.Text
  serviceType     String?
  requirements    String?    @db.Text
  notes           String?    @db.Text
  status          LeadStatus @default(NEW)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status])
}

// ==========================================
// MODULE 8: Rental Leads
// ==========================================

model RentalLead {
  id                String          @id @default(uuid())
  pickupLocation    String
  dropLocation      String?
  pickupDateTime    DateTime
  returnDateTime    DateTime?
  vehicleCategoryId String
  vehicleCategory   VehicleCategory @relation(fields: [vehicleCategoryId], references: [id], onDelete: Restrict)
  customerName      String
  email             String
  phone             String
  tripType          String?
  notes             String?         @db.Text
  status            LeadStatus      @default(NEW)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([status])
  @@index([vehicleCategoryId])
}

// ==========================================
// MODULE 9: Contact Leads
// ==========================================

model ContactLead {
  id        String     @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String     @db.Text
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
}

// ==========================================
// MODULE 11: Blog Categories
// ==========================================

model BlogCategory {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  blogPosts   BlogPost[]

  @@index([slug])
}

// ==========================================
// MODULE 10: Blog Posts
// ==========================================

model BlogPost {
  id             String       @id @default(uuid())
  title          String
  slug           String       @unique
  summary        String       @db.Text
  content        String       @db.Text
  featuredImage  String?
  published      Boolean      @default(false)
  publishedAt    DateTime?
  authorId       String
  author         Admin        @relation(fields: [authorId], references: [id], onDelete: Restrict)
  categoryId     String
  category       BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  tags           String[]
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([slug])
  @@index([categoryId, published])
}

// ==========================================
// MODULE 12: Testimonials
// ==========================================

model Testimonial {
  id          String   @id @default(uuid())
  authorName  String
  authorRole  String?
  companyName String?
  content     String   @db.Text
  rating      Int      @default(5)
  avatarUrl   String?
  isFeatured  Boolean  @default(false)
  status      String   @default("APPROVED") // APPROVED, PENDING, REJECTED
  createdAt   DateTime @default(now())

  @@index([status, isFeatured])
}

// ==========================================
// MODULE 13: Gallery
// ==========================================

model Gallery {
  id        String    @id @default(uuid())
  title     String?
  imageUrl  String
  mediaType MediaType @default(IMAGE)
  category  String?   // e.g. fleet, tours, corporate
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([category, sortOrder])
}

// ==========================================
// MODULE 14: Bookings
// ==========================================

model Booking {
  id                String          @id @default(uuid())
  bookingNumber     String          @unique
  customerId        String
  customer          User            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicleId         String?
  vehicle           FleetVehicle?   @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  vehicleCategoryId String
  vehicleCategory   VehicleCategory @relation(fields: [vehicleCategoryId], references: [id], onDelete: Restrict)
  type              BookingType
  status            BookingStatus   @default(PENDING)
  pickupDateTime    DateTime
  pickupLocation    String
  dropLocation      String?
  estimatedDistance Decimal?        @db.Decimal(8, 2)
  estimatedDuration Int?            // in minutes
  totalAmount       Decimal         @db.Decimal(10, 2)
  taxAmount         Decimal         @default(0.0) @db.Decimal(10, 2)
  discountAmount    Decimal         @default(0.0) @db.Decimal(10, 2)
  netAmount         Decimal         @db.Decimal(10, 2)
  notes             String?         @db.Text
  outstationType    OutstationType?
  returnDateTime    DateTime?
  rentalDurationHrs Int?
  rentalDurationKms Int?
  tourPackageId     String?
  tourPackage       TourPackage?    @relation(fields: [tourPackageId], references: [id], onDelete: SetNull)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  payments          RazorpayPayment[]

  @@index([bookingNumber])
  @@index([customerId])
  @@index([status])
  @@index([vehicleId])
}

// ==========================================
// MODULE 15: Razorpay Payments
// ==========================================

model RazorpayPayment {
  id                String        @id @default(uuid())
  bookingId         String
  booking           Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  gateway           String        @default("RAZORPAY")
  razorpayOrderId   String        @unique
  razorpayPaymentId String?       @unique
  razorpaySignature String?
  status            PaymentStatus @default(PENDING)
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("INR")
  gatewayResponse   Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([bookingId])
  @@index([razorpayOrderId])
}

// ==========================================
// MODULE 16: Site Settings
// ==========================================

model SiteSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?  @db.Text
  updatedAt   DateTime @updatedAt

  @@index([key])
}
